{
  "name": "@local/mxc-sandbox",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "bunx tsc --noEmit -p tsconfig.json",
    "build:extension": "bun run scripts/build-extension.ts",
    "postinstall": "bun run build:extension",
    "test:unit": "bun test --timeout 30000 test/policy.test.ts test/path-policy.test.ts test/state-permissions.test.ts test/omp-integration.test.ts test/execution.test.ts",
    "test:e2e:macos": "bun test --timeout 120000 test/e2e/macos.test.ts",
    "test:e2e:windows": "bun test --timeout 120000 test/e2e/windows.test.ts"
  },
  "omp": {
    "extensions": ["./dist/index.js"]
  },
  "dependencies": {
    "@microsoft/mxc-sdk": "^0.7.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.19",
    "typescript": "^5.8.3"
  }
}
